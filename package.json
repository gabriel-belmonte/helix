{
  "name": "helix",
  "private": true,
  "workspaces": [
    "packages/agent",
    "packages/core",
    "packages/cli",
    "packages/eval",
    "packages/mcp",
    "packages/tui",
    "packages/memory",
    "packages/web",
    "packages/site"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:agent": "turbo run build --filter=helix-agent",
    "build:cli": "turbo run build --filter=helix-agent-cli",
    "build:eval": "turbo run build --filter=helix-agent-eval",
    "build:site": "turbo run build --filter=helix-site",
    "test": "turbo run test",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "react-devtools-core": "^7.0.1",
    "turbo": "^2.0.0"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.18",
    "@ai-sdk/openai": "^4.0.18",
    "ai": "^7.0.35"
  },
  "funding": [
    {
      "type": "Buy Me a Coffee",
      "url": "https://buymeacoffee.com/gabrielbelmonte"
    },
    {
      "type": "Ko-fi",
      "url": "https://ko-fi.com/gabrielbelmonte"
    }
  ]
}
