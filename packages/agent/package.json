{
  "name": "helix-agent",
  "version": "0.1.1",
  "description": "Minimal TypeScript SDK to orchestrate AI agents and tools — a lightweight, transparent alternative to LangChain.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./vercel": {
      "types": "./dist/src/vercel.d.ts",
      "import": "./dist/src/vercel.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsx --test test/*.test.ts",
    "demo": "tsx examples/hello-agent.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "agents",
    "llm",
    "typescript",
    "orchestration",
    "langchain-alternative",
    "vercel"
  ],
  "author": "gabriel-belmonte",
  "license": "MIT",
  "dependencies": {
    "ai": "^5.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/anthropic": "^2.0.0"
  },
  "peerDependencies": {},
  "peerDependenciesMeta": {},
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.11.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
