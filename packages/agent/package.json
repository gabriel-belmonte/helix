{
  "name": "helix-agent",
  "version": "0.2.7",
  "description": "Minimal TypeScript SDK to orchestrate AI agents and tools — a lightweight, transparent alternative to LangChain.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./vercel": {
      "types": "./dist/src/vercel.d.ts",
      "import": "./dist/src/vercel.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test test/*.test.ts",
    "demo": "tsx examples/hello-agent.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "agents",
    "llm",
    "typescript",
    "orchestration",
    "langchain-alternative",
    "vercel"
  ],
  "author": "gabriel-belmonte",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabriel-belmonte/helix"
  },
  "license": "MIT",
  "dependencies": {},
  "peerDependencies": {
    "ai": "^7.0.35"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": false
    }
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "@types/node": "^26.1.1"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
