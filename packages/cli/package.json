{
  "name": "helix-agent-cli",
  "version": "0.1.0",
  "description": "A minimal, transparent coding agent CLI built on helix-agent. Native bun binary, curl install, helix config command.",
  "type": "module",
  "bin": {
    "helix": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build packages/cli/cli.ts --compile --outfile helix 2>&1 | tail -1",
    "typecheck": "tsc --noEmit 2>&1 | head -10 || true",
    "start": "tsx cli.ts",
    "test": "bun test",
    "demo": "tsx cli.ts -p \"List the files in the current directory\" --scripted",
    "clean": "rm -rf dist helix"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "coding-agent",
    "llm",
    "terminal"
  ],
  "author": "gabriel-belmonte",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "helix-agent": "*",
    "helix-core": "*",
    "helix-mcp": "*",
    "helix-agent-eval": "*",
    "ora": "^9.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
