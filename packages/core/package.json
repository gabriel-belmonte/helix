{
  "name": "helix-core",
  "version": "0.1.0",
  "description": "Helix shared core: agent runtime, tool registry, plugin system, config schema. Single source of truth for all Helix surfaces (CLI, TUI, web, Dashboard, Desktop).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "extract-server"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('extract-server','dist/extract-server',{recursive:true})\"",
    "test": "bun test test/*.test.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "agents",
    "helix",
    "plugin",
    "runtime"
  ],
  "author": "gabriel-belmonte",
  "license": "MIT",
  "dependencies": {
    "helix-agent": "*",
    "helix-memory": "*",
    "@ai-sdk/openai": "^4.0.18",
    "@ai-sdk/anthropic": "^4.0.18"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^26.1.1"
  },
  "private": true
}
