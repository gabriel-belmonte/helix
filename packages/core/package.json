{
  "name": "helix-core",
  "version": "0.1.0",
  "description": "Helix shared core: agent runtime, tool registry, plugin system, config schema. Single source of truth for all Helix surfaces (CLI, TUI, web, Dashboard, Desktop).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "extract-server"],
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('extract-server','dist/extract-server',{recursive:true})\"",
    "test": "tsx --test test/*.test.ts",
    "clean": "rm -rf dist"
  },
  "keywords": ["ai", "agents", "helix", "plugin", "runtime"],
  "author": "gabriel-belmonte",
  "license": "MIT",
  "dependencies": {
    "helix-agent": "*",
    "helix-memory": "*",
    "@ai-sdk/openai": "^1.3.0",
    "@ai-sdk/anthropic": "^1.0.0",
    "ai": "^4.3.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.11.0"
  }
}
