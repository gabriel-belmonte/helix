{
  "name": "helix-web",
  "version": "0.1.0",
  "description": "Helix Dashboard — web control panel (config, keys, skills, MCP, files) over the same core.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:api\" \"bun run dev:ui\"",
    "dev:api": "bun --hot server/index.ts",
    "dev:ui": "vite",
    "build": "vite build",
    "start": "bun run server/index.ts",
    "test": "bun test test/*.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "helix-core": "*",
    "helix-mcp": "*",
    "hono": "^4.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "vite": "^5.4.0"
  }
}
